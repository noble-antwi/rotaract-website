---
import Base from '../../layouts/Base.astro';
import UpdateCard from '../../components/UpdateCard.astro';
import { getUpdates, updateThumb } from '../../lib/sanity';

const updates = await getUpdates();
---
<Base title="Updates — Rotaract Club of Chicago" description="Weekly recaps, photos, and videos from the Rotaract Club of Chicago.">
  <section class="pagehead">
    <div class="aurora a1"></div><div class="aurora a2"></div>
    <div class="wrap">
      <span class="eyebrow" style="color:var(--gold)">Updates</span>
      <h1>Fresh from <em>the club</em></h1>
      <p>Weekly recaps from our meetings, service projects, and socials — photos, stories, and the occasional video.</p>
    </div>
  </section>

  <section class="updates" style="padding-top:80px">
    <div class="wrap">
      {updates.length > 0 ? (
        <div class="upd-grid">
          {updates.map((u, i) => (
            <UpdateCard
              slug={u.slug}
              title={u.title}
              date={u.date}
              excerpt={u.excerpt}
              image={updateThumb(u)}
              isVideo={!!u.youtube}
              class={`d${(i % 3) + 1}`}
            />
          ))}
        </div>
      ) : (
        <p style="color:#41506C;font-size:18px">Our first updates are coming soon — check back shortly!</p>
      )}
    </div>
  </section>
</Base>
