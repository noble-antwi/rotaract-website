---
import Base from '../../layouts/Base.astro';
import { getUpdateSlugs, getUpdate, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const slugs = await getUpdateSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getUpdate(slug!);
if (!post) return Astro.redirect('/updates');

const fmt = new Date(post.date).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});

const bodyHtml = post.body
  ? toHTML(post.body, {
      components: {
        marks: {
          link: ({ children, value }) =>
            `<a href="${value?.href}" target="_blank" rel="noopener">${children}</a>`,
        },
      },
    })
  : '';

const coverUrl = post.cover
  ? urlFor(post.cover).width(1280).height(720).fit('crop').auto('format').url()
  : null;
const galleryUrls = (post.gallery || []).map((g) =>
  urlFor(g).width(800).height(600).fit('crop').auto('format').url(),
);
---
<Base title={`${post.title} — Rotaract Club of Chicago`} description={post.excerpt}>
  <article class="post" style="padding-top:140px">
    <div class="wrap">
      <a class="back" href="/updates"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M11 18l-6-6 6-6"/></svg> All updates</a>
      <p class="meta">{fmt}</p>
      <h1 style="font-weight:400;font-size:clamp(32px,5vw,56px);line-height:1.05;letter-spacing:-.025em">{post.title}</h1>

      {post.youtube ? (
        <div class="video">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${post.youtube}`}
            title={post.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ) : coverUrl ? (
        <div class="cover"><img src={coverUrl} alt={post.title} /></div>
      ) : null}

      <div class="content" set:html={bodyHtml} />

      {galleryUrls.length > 0 && (
        <div class="gallery">
          {galleryUrls.map((src) => <img src={src} alt="" loading="lazy" />)}
        </div>
      )}
    </div>
  </article>
</Base>
