---
const links = [
  { href: '/#what', label: 'What we do' },
  { href: '/#about', label: 'About' },
  { href: '/#leaders', label: 'Team' },
  { href: '/updates', label: 'Updates' },
  { href: '/#events', label: 'Events' },
  { href: '/#why', label: 'Our why' },
];
---
<header class="site" id="header">
  <div class="wrap nav">
    <a class="brand" href="/" aria-label="Rotaract Club of Chicago — home">
      <svg class="wheel" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <g class="spin">
          <circle cx="24" cy="24" r="20" stroke="#F8B528" stroke-width="2.5"/>
          <g fill="#F8B528">
            <rect x="22.5" y="1" width="3" height="6" rx="1.5"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(45 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(90 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(135 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(180 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(225 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(270 24 24)"/>
            <rect x="22.5" y="1" width="3" height="6" rx="1.5" transform="rotate(315 24 24)"/>
          </g>
        </g>
        <circle cx="24" cy="24" r="7" fill="#E11873"/><circle cx="24" cy="24" r="3.2" fill="#fff"/>
      </svg>
      <span><b>Rotaract</b><small>CHICAGO</small></span>
    </a>
    <button class="burger" aria-label="Toggle menu" id="burger">☰</button>
    <ul class="menu" id="menu">
      {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      <li><a class="btn btn-fill" href="/#join">Join us →</a></li>
    </ul>
  </div>
</header>
