---
import Base from '../layouts/Base.astro';
import { SITE } from '../config';

const benefits = [
  { t: 'Meaningful service', d: 'Hands-on projects that make a real difference in Chicago and beyond.' },
  { t: 'Leadership experience', d: 'Lead projects, run events, and build skills that matter in your career.' },
  { t: 'A real network', d: 'Meet service-minded students and young professionals across the city.' },
  { t: 'Social life included', d: 'Monthly socials, mixers, and roundtables — service should be fun.' },
  { t: 'Global Rotary family', d: 'Plug into Rotary International’s worldwide network and opportunities.' },
  { t: 'Flexible commitment', d: 'Come to what you can. A couple of events a month is a great start.' },
];

const faqs = [
  { q: 'Who can join?', a: 'Students and young professionals (roughly 18–30) who want to serve, lead, and meet good people. Everyone is welcome.' },
  { q: 'Do I need any Rotary experience?', a: 'Not at all. Most members start with zero Rotary background — we’ll show you the ropes.' },
  { q: 'What’s the time commitment?', a: 'It’s flexible. Many members come to a couple of events a month. Do more if you love it.' },
  { q: 'Are there membership dues?', a: 'There are modest annual dues that support our service projects. Reach out and we’ll share the current details.' },
  { q: 'How do I get started?', a: 'Come to an event to meet us, or email us to introduce yourself — then we’ll help you join.' },
];

const applySubject = encodeURIComponent('I’d like to join the Rotaract Club of Chicago');
const applyBody = encodeURIComponent(
  'Hi Rotaract Chicago,\n\nMy name is ____ and I’d love to learn more about becoming a member.\n\nA bit about me:\n- \n\nThanks!',
);
---
<Base title="Join — Rotaract Club of Chicago" description="Become a member of the Rotaract Club of Chicago — a service and social club for students and young professionals.">
  <section class="pagehead">
    <div class="aurora a1"></div><div class="aurora a2"></div>
    <div class="wrap">
      <span class="eyebrow" style="color:var(--gold)">Membership</span>
      <h1>Come do some <em>good</em> with us</h1>
      <p>If you want to serve, lead, and meet genuinely good people — you’re exactly who we’re looking for. No Rotary experience needed.</p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="membership-benefits">
    <div class="wrap">
      <span class="eyebrow reveal">Why join</span>
      <h2 class="reveal d1">What you get out of it</h2>
      <div class="benefit-grid">
        {benefits.map((b, i) => (
          <div class={`benefit reveal d${(i % 3) + 1}`}>
            <h3>{b.t}</h3>
            <p>{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="join" id="how">
    <div class="wrap join-grid">
      <div>
        <span class="eyebrow reveal">How to join</span>
        <h2 class="reveal d1">Three simple <span class="h2-serif">steps</span></h2>
        <p class="sub reveal d2">Membership really does start with just showing up. Here’s the path from curious to card-carrying member.</p>
        <a class="btn btn-fill magnetic reveal d3" href={`mailto:${SITE.email}?subject=${applySubject}&body=${applyBody}`} style="margin-top:30px">Email us to join <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
      <div class="steps">
        <div class="step reveal d1"><span class="n">01</span><div><b>Come to an event</b><span>Join a social or service event and see if we’re a fit.</span></div></div>
        <div class="step reveal d2"><span class="n">02</span><div><b>Reach out</b><span>Email {SITE.email} and introduce yourself.</span></div></div>
        <div class="step reveal d3"><span class="n">03</span><div><b>Become a member</b><span>We’ll walk you through membership and get you plugged in.</span></div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="wrap">
      <span class="eyebrow reveal">Good to know</span>
      <h2 class="reveal d1">Frequently asked <span class="h2-serif">questions</span></h2>
      <div class="faq reveal d1">
        {faqs.map((f) => (
          <details>
            <summary>{f.q}<span class="chev" aria-hidden="true"></span></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Apply CTA -->
  <section class="cta">
    <div class="wrap">
      <h2 class="reveal">Ready when <em>you</em> are</h2>
      <p class="reveal d1">Send us a note and a member will get back to you with the next steps.</p>
      <a class="btn btn-fill magnetic reveal d2" href={`mailto:${SITE.email}?subject=${applySubject}&body=${applyBody}`}>Apply to join <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>
</Base>
