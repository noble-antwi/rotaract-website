---
import { avatarPhoto, img } from '../config';
import { urlFor, type Leader } from '../lib/sanity';

// Headshot used for each standard role's placeholder (real-looking dummy).
const ROLE_AVATAR: Record<string, number> = {
  president: 12,
  'vice president': 13,
  secretary: 45,
  treasurer: 32,
};

// Real people hard-wired for roles not yet entered in the CMS.
// (If a real leader with the same role is published in Sanity, that wins.)
const ROLE_OVERRIDE: Record<string, { name: string; photo: string; linkedin?: string }> = {
  president: { name: 'Taylor Thompkins', photo: img('taylor.jpg') },
  'vice president': { name: 'Evan Carnes', photo: img('evan.jpg') },
  secretary: { name: 'Diane Peres', photo: img('diane.jpg') },
  treasurer: { name: 'Dennis Evashenk', photo: img('dennis.jpg') },
};

interface Props {
  leaders?: Leader[];
}
const { leaders = [] } = Astro.props;

// Standard officer roles — empty ones are shown as placeholders for now,
// so the section always looks complete as real officers are added in the CMS.
const STANDARD_ROLES = ['President', 'Vice President', 'Secretary', 'Treasurer'];

const real = leaders.map((p) => ({
  name: p.name,
  role: p.role,
  linkedin: p.linkedin || '',
  photo: p.photo
    ? urlFor(p.photo).width(600).height(700).fit('crop').auto('format').url()
    : avatarPhoto(8),
  placeholder: false,
}));

// Fill any standard role that doesn't yet have a real person with a placeholder.
const filledRoles = new Set(real.map((p) => p.role.trim().toLowerCase()));
const fillers = STANDARD_ROLES.filter((r) => !filledRoles.has(r.toLowerCase())).map((role) => {
  const ov = ROLE_OVERRIDE[role.toLowerCase()];
  return {
    name: ov?.name ?? 'First Last',
    role,
    linkedin: ov?.linkedin ?? '',
    photo: ov?.photo ?? avatarPhoto(ROLE_AVATAR[role.toLowerCase()] ?? 8),
    placeholder: !ov, // a real override is not a placeholder
  };
});

// Order by standard role; anyone with a non-standard role goes last.
const rank = (r: string) => {
  const i = STANDARD_ROLES.findIndex((s) => s.toLowerCase() === r.toLowerCase());
  return i < 0 ? 99 : i;
};
const people = [...real, ...fillers].sort((a, b) => rank(a.role) - rank(b.role));
---
<section class="leaders" id="leaders">
  <div class="wrap">
    <div class="svc-head">
      <div>
        <span class="eyebrow reveal">Leadership</span>
        <h2 class="reveal d1">Meet the <span class="h2-serif">team</span></h2>
      </div>
      <p class="reveal d2" style="max-width:34ch;color:#41506C;font-size:16px">The members who keep the club running and the projects moving.</p>
    </div>
    <div class="leader-grid">
      {people.map((p, i) => (
        <article class={`leader reveal d${(i % 4) + 1}${p.placeholder ? ' is-placeholder' : ''}`}>
          <div class="leader-photo">
            <img src={p.photo} alt={p.name} loading="lazy" />
            {p.linkedin && (
              <a class="leader-li" href={p.linkedin} target="_blank" rel="noopener" aria-label={`${p.name} on LinkedIn`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zM8.34 18.34V9.99H5.67v8.35zM7 8.84a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1m11.34 9.5v-4.58c0-2.45-1.31-3.59-3.06-3.59a2.64 2.64 0 0 0-2.39 1.31v-1.13h-2.67v8.35h2.67v-4.41c0-1.16.22-2.29 1.66-2.29s1.42 1.33 1.42 2.36v4.34z"/></svg>
              </a>
            )}
          </div>
          <h3>{p.name}</h3>
          <span class="leader-role">{p.role}</span>
        </article>
      ))}
    </div>
  </div>
</section>
